
from fastapi import FastAPI, HTTPException, Request, BackgroundTasks
from fastapi.responses import PlainTextResponse, JSONResponse
from twilio.twiml.messaging_response import MessagingResponse
from twilio.request_validator import RequestValidator
from dotenv import load_dotenv
import os
import logging
from app.agent import E_TailoringAgent

load_dotenv()

app = FastAPI(title="E-Tailoring WhatsApp Agent")

# Configure logging
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# Initialize agent
agent = E_TailoringAgent(api_key=os.getenv("OPENAI_API_KEY"))

# Store active conversations (in production, use Redis or database)
active_conversations = {}

@app.get("/")
async def root():
    return {"status": "healthy", "service": "E-Tailoring WhatsApp Agent"}

@app.post("/webhook", response_class=PlainTextResponse)
async def whatsapp_webhook(request: Request):
    """
    Main webhook endpoint for WhatsApp messages via Twilio
    """
    try:
        # Parse incoming message
        form_data = await request.form()
        incoming_msg = form_data.get("Body", "").strip()
        sender_id = form_data.get("From", "")
        sender_name = form_data.get("ProfileName", "Customer")
        
        if not incoming_msg:
            return MessagingResponse().to_xml()
        
        logger.info(f"Message from {sender_name} ({sender_id}): {incoming_msg}")
        
        # Get or create conversation state
        if sender_id not in active_conversations:
            active_conversations[sender_id] = {
                "messages": [],
                "handoff_active": False
            }
        
        conv_state = active_conversations[sender_id]
        
        # If human handoff is active, don't respond automatically
        if conv_state.get("handoff_active"):
            return MessagingResponse().to_xml()
        
        # Add user message to state
        conv_state["messages"].append({
            "role": "user",
            "content": incoming_msg
        })
        
        # Process through LangGraph agent
        agent_state = await agent.workflow.ainvoke({
            "messages": conv_state["messages"],
            "sentiment_score": 0,
            "needs_human": False,
            "context": {},
            "conversation_id": sender_id
        })
        
        # Check if handoff needed
        if agent_state["needs_human"]:
            conv_state["handoff_active"] = True
            # Notify human team (implement your notification logic)
            await notify_human_team(sender_id, sender_name, conv_state["messages"])
        
        # Get the last assistant response
        assistant_response = agent_state["messages"][-1]["content"]
        conv_state["messages"].append({
            "role": "assistant",
            "content": assistant_response
        })
        
        # Send response via Twilio
        resp = MessagingResponse()
        resp.message(assistant_response)
        
        logger.info(f"Response to {sender_name}: {assistant_response[:100]}...")
        return str(resp)
        
    except Exception as e:
        logger.error(f"Webhook error: {str(e)}")
        return MessagingResponse().to_xml()

async def notify_human_team(sender_id: str, sender_name: str, conversation_history: list):
    """
    Notify human agents about handoff (Slack, email, or custom webhook)
    """
    # Example: Send to Slack webhook
    import httpx
    slack_webhook = os.getenv("SLACK_WEBHOOK_URL")
    if slack_webhook:
        async with httpx.AsyncClient() as client:
            await client.post(slack_webhook, json={
                "text": f"🚨 *Handoff Required*\nCustomer: {sender_name} ({sender_id})\nReason: Negative sentiment or explicit request",
                "attachments": [{
                    "text": f"Conversation preview:\n{conversation_history[-3:]}",
                    "color": "danger"
                }]
            })

@app.get("/conversations/{customer_id}")
async def get_conversation(customer_id: str):
    """API endpoint for human agents to view conversation history"""
    if customer_id in active_conversations:
        return JSONResponse(content={
            "conversation_id": customer_id,
            "history": active_conversations[customer_id]["messages"],
            "handoff_active": active_conversations[customer_id]["handoff_active"]
        })
    return JSONResponse(content={"error": "Conversation not found"}, status_code=404)

@app.post("/conversations/{customer_id}/handoff/reset")
async def reset_handoff(customer_id: str):
    """Allow human agent to hand control back to bot"""
    if customer_id in active_conversations:
        active_conversations[customer_id]["handoff_active"] = False
        return JSONResponse(content={"status": "handoff_reset", "customer_id": customer_id})
    return JSONResponse(content={"error": "Conversation not found"}, status_code=404)

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000, reload=True)